{
  "name": "citadel-cli-monorepo",
  "description": "Monorepo workspace for Citadel: @citadel/core (engine), citadel_cli (React library), @citadel/cli (terminal)",
  "author": {
    "name": "James Childers",
    "email": "james.childers@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchilders/citadel_cli.git"
  },
  "version": "1.5.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build -w citadel_cli",
    "verify:pack": "npm run verify:pack -w citadel_cli",
    "dev": "npm run dev -w citadel_cli",
    "preview": "npm run preview -w citadel_cli",
    "build:demo": "npm run build:demo -w citadel_cli",
    "coffee-bar": "npm run coffee-bar -w @citadel/cli",
    "game-master": "npm run game-master -w @citadel/cli",
    "basic-cli": "npm run basic-cli -w @citadel/cli",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest --run",
    "test:e2e": "npm run test:e2e -w citadel_cli",
    "test:e2e:ui": "npm run test:e2e:ui -w citadel_cli",
    "coverage": "NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
    "metrics:build": "node scripts/metrics/collect-build-metrics.mjs",
    "metrics:runtime": "node scripts/metrics/collect-runtime-metrics.mjs",
    "metrics:compare": "node scripts/metrics/compare-metrics.mjs",
    "metrics:all": "node scripts/metrics/run-all-metrics.mjs",
    "metrics:report": "node scripts/metrics/run-all-metrics.mjs --skip-build --skip-runtime",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.1.5",
    "vite-plugin-dts": "^4.5.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.6"
  }
}
