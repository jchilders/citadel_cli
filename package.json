{
  "name": "citadel_cli",
  "description": "Keyboard-driven command console for React apps — built for internal tools, admin panels, and dev debug overlays",
  "keywords": [
    "react",
    "command",
    "cli",
    "interface",
    "console",
    "terminal",
    "command-palette",
    "internal-tools",
    "admin-panel",
    "devtools"
  ],
  "author": {
    "name": "James Childers",
    "email": "james.childers@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jchilders/citadel_cli.git"
  },
  "version": "1.5.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc && vite build && node scripts/sync-package-artifacts.mjs",
    "verify:pack": "node scripts/verify-package-artifacts.mjs",
    "dev": "vite",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview",
    "test": "NODE_OPTIONS=--no-experimental-webstorage vitest --run",
    "test:e2e": "NODE_OPTIONS=--disable-warning=DEP0205 playwright test",
    "test:e2e:ui": "NODE_OPTIONS=--disable-warning=DEP0205 playwright test --ui",
    "coverage": "NODE_OPTIONS=--no-experimental-webstorage vitest run --coverage",
    "metrics:build": "node scripts/metrics/collect-build-metrics.mjs",
    "metrics:runtime": "node scripts/metrics/collect-runtime-metrics.mjs",
    "metrics:compare": "node scripts/metrics/compare-metrics.mjs",
    "metrics:all": "node scripts/metrics/run-all-metrics.mjs",
    "metrics:report": "node scripts/metrics/run-all-metrics.mjs --skip-build --skip-runtime",
    "build:demo": "vite build --config vite.demo.config.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/citadel.es.js",
      "require": "./dist/citadel.umd.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/citadel.umd.cjs",
  "module": "./dist/citadel.es.js",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.2",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.6",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "typescript": "^5.4.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.1.5",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^2.1.6"
  }
}
