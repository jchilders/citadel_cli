{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@citadel/core": ["./packages/core/src/index.ts"],
      "@citadel/cli": ["./packages/cli/src/index.ts"],
      "@citadel/sample-commands": ["./packages/sample-commands/src/index.ts"]
    },
    "types": [
      "vitest",
      "vitest/globals"
    ]
  },
  "include": ["packages/*/src/**/*", "packages/*/examples/**/*"],
  "exclude": ["node_modules", "**/dist"]
}
