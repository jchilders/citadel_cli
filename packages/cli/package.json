{
  "name": "@citadel_cli/cli",
  "version": "1.7.0",
  "description": "Terminal front-end for Citadel — drives the @citadel_cli/core command engine in a full-screen Ink TUI",
  "license": "MIT",
  "author": {
    "name": "James Childers",
    "email": "james.childers@gmail.com"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
